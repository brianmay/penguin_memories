{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  /*
   * Avoid churn
   */
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  /*
   * Make failures obvious instead of retrying forever
   */
  "rebaseWhen": "conflicted",
  /*
   * Keep in sync with the Elixir version in flake.nix. Containerbase
   * cannot install release candidates, so use the closest final release.
   */
  "constraints": {
    "elixir": "1.20.1"
  }
}